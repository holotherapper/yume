ANTHROPIC_API_KEY=

# Optional UI/backend default. Each run can override this from the web UI.
YUME_DEFAULT_MODEL_ID=claude-opus-4-7
# Managed Agents exposes inference speed, not a separate effort setting.
YUME_DEFAULT_MODEL_SPEED=standard

# Generated Managed Agents IDs are stored in core/data/managed-agents.json.
# That file is local-only and ignored by git.
